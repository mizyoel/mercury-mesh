{
  "version": 1,
  "schedules": [
    {
      "id": "ralph-heartbeat",
      "name": "Ralph Heartbeat",
      "enabled": true,
      "trigger": {
        "type": "interval",
        "intervalSeconds": 300
      },
      "task": {
        "type": "workflow",
        "ref": ".github/workflows/mesh-heartbeat.yml"
      },
      "providers": ["local-polling", "github-actions"]
    },
    {
      "id": "org-runtime-reconcile",
      "name": "Org Runtime Reconcile",
      "enabled": false,
      "trigger": {
        "type": "interval",
        "intervalSeconds": 900
      },
      "task": {
        "type": "script",
        "ref": ".mesh/org/reconcile.js",
        "args": ["--mesh-dir", ".mesh", "--output", "org-runtime-results.json"]
      },
      "providers": ["local-polling"]
    },
    {
      "id": "org-backlog-from-triage",
      "name": "Org Backlog From Triage",
      "enabled": false,
      "trigger": {
        "type": "event",
        "event": "triage-complete"
      },
      "task": {
        "type": "script",
        "ref": ".mesh/org/backlog-from-triage.js",
        "args": ["--mesh-dir", ".mesh", "--triage-file", "triage-results.json", "--output", "org-backlog-results.json"]
      },
      "providers": ["local-polling"]
    },
    {
      "id": "org-status",
      "name": "Org Status Snapshot",
      "enabled": false,
      "trigger": {
        "type": "interval",
        "intervalSeconds": 600
      },
      "task": {
        "type": "script",
        "ref": ".mesh/org/status.js",
        "args": ["--mesh-dir", ".mesh", "--output", "org-status.json"]
      },
      "providers": ["local-polling"]
    }
  ]
}
