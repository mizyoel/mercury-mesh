# Production deployment template.
# Copy values into your real deployment secret store or an untracked `.env.production` file.

NODE_ENV=production
OPENROUTER_API_KEY=<set-openrouter-api-key>
GITHUB_TOKEN=<set-github-token>

# Optional alias if your runtime is standardized on MESH_EMBEDDING_KEY.
MESH_EMBEDDING_KEY=<optional-mesh-embedding-key>