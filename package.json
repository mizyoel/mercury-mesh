{
  "name": "@mizyoel/mercury-mesh",
  "version": "1.2.0",
  "description": "Mercury Mesh runtime templates, prompts, workflows, and skills for Fluid OS autonomous operations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizyoel/mercury-mesh.git"
  },
  "homepage": "https://github.com/mizyoel/mercury-mesh#readme",
  "bugs": {
    "url": "https://github.com/mizyoel/mercury-mesh/issues"
  },
  "type": "commonjs",
  "main": "index.cjs",
  "bin": {
    "mercury-mesh": "bin/mercury-mesh.cjs"
  },
  "exports": {
    ".": "./index.cjs",
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "docs/",
    "index.cjs",
    "bin/",
    ".copilot/",
    ".github/agents/",
    ".mesh/manifesto.md",
    ".mesh/templates/"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "mercury-mesh",
    "mizyoel",
    "copilot",
    "github-copilot",
    "agents",
    "ai-agents",
    "agentic",
    "agentic-flows",
    "agent-orchestration",
    "multi-agent",
    "multi-agent-systems",
    "autonomous-agents",
    "ai-workflows",
    "templates",
    "workflows"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "@lancedb/lancedb": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "@lancedb/lancedb": {
      "optional": true
    }
  }
}
